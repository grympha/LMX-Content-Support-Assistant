{
  "event_type": "workflow_started",
  "storage_table": "training_events",
  "payload_fields": {
    "eventType": "workflow_started",
    "username": "session username (lowercase, from HMAC cookie)",
    "topic": "shortcut analyticsLabel (e.g. 'Create New Device')",
    "details": "shortcut id (e.g. 'wf-001')"
  },
  "trigger": "shortcut button click in IntakeSidebar",
  "source_file": "src/components/IntakeSidebar.tsx",
  "analytics_library": "src/lib/progressLog.ts",
  "admin_visibility": [
    {
      "dashboard": "Training Tab → Search Analytics",
      "widget": "Top 10 Most-Searched Questions",
      "note": "workflow_started events with topic field appear alongside question_asked events"
    },
    {
      "dashboard": "Training Tab → Training Records",
      "widget": "Full event log",
      "filter": "Filter by event type 'workflow_started' to see all shortcut usage"
    }
  ],
  "workflows": [
    {
      "id": "wf-001",
      "analytics_label": "Create New Device",
