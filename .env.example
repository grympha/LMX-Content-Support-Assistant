APP_PASSWORD=change-me
ADMIN_PASSWORD=change-me-admin
OPENAI_API_KEY=
CLAUDE_API_KEY=
CLAUDE_MODEL=
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
GOOGLE_SCRIPT_URL=YOUR_GOOGLE_APPS_SCRIPT_WEBHOOK_URL

# Neon PostgreSQL — required for conversation history persistence
# Create a free database at https://neon.tech and paste the connection string here.
# Without this, conversation history is disabled but the assistant still works.
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Maximum saved conversations per user (oldest deleted when limit is reached)
MAX_CONVERSATIONS_PER_USER=50
